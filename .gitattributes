# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf

# Binary files
*.tif binary
*.tiff binary
*.vrt binary
*.7z binary
*.zip binary
*.tar binary
*.gz binary

# QGIS project files
*.qgz binary
*.qgs binary

# Document files
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
